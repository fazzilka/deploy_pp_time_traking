APP_PORT=8000
WEB_CONCURRENCY=2
LOG_LEVEL=INFO

POSTGRES_DB=time_tracking
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30

JWT_SECRET_KEY=CHANGE_ME_SECRET_KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Для запуска без домена укажи IP. Когда появится домен — замени на https://domain.ru
CORS_ALLOW_ORIGINS=http://SERVER_IP_OR_DOMAIN,http://localhost,http://127.0.0.1

ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ADMIN_FULL_NAME=Администратор

GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
