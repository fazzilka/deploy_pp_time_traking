APP_PORT=8000
WEB_CONCURRENCY=2
LOG_LEVEL=INFO

POSTGRES_DB=time_tracking
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30

JWT_SECRET_KEY=CHANGE_ME_SECRET_KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Для запуска без домена укажи IP. Когда появится домен — замени на https://domain.ru
CORS_ALLOW_ORIGINS=http://SERVER_IP_OR_DOMAIN,http://localhost,http://127.0.0.1
APP_PUBLIC_URL=https://time-tracking.online

RABBITMQ_DEFAULT_USER=time_tracking
RABBITMQ_DEFAULT_PASS=CHANGE_ME_STRONG_PASSWORD
RABBITMQ_DEFAULT_VHOST=/
CELERY_BROKER_URL=amqp://time_tracking:CHANGE_ME_STRONG_PASSWORD@rabbitmq:5672//
CELERY_TASK_ALWAYS_EAGER=false
DEADLINE_REMINDER_MINUTES=60

EMAIL_NOTIFICATIONS_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Time Tracking
SMTP_USE_TLS=true
SMTP_USE_SSL=false

TELEGRAM_NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=

ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ADMIN_FULL_NAME=Администратор

GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Deploy script settings
# APP_DIR is used before this file is loaded. Override it as a shell variable if the app is not in /opt/time-tracking.
APP_DIR=/opt/time-tracking
COMPOSE_FILE=docker-compose.prod.yml
ENV_FILE=.env
BACKUP_DIR=/opt/time-tracking/backups
HEALTH_TIMEOUT_SECONDS=120
HEALTH_INTERVAL_SECONDS=5
BACKEND_HEALTH_URL=http://127.0.0.1:8000/health
FRONTEND_HEALTH_URL=http://127.0.0.1:8080/
RUN_DB_BACKUP=true
RUN_MIGRATIONS=true
PRUNE_AFTER_SUCCESS=true
BACKUP_RETENTION_DAYS=7
FORCE_DEPLOY_FAIL_AFTER_UP=false
